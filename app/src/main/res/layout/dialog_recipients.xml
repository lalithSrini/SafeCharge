<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="Enter emails to receive theft alerts and photos."
        style="@style/TextAppearance.SafeCharge.BodyMedium" />

    <EditText
        android:id="@+id/etRecipient1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/edittext_bg"
        android:hint="Recipient 1 (Required)"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_dim" />

    <EditText
        android:id="@+id/etRecipient2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/edittext_bg"
        android:hint="Recipient 2 (Optional)"
        android:inputType="textEmailAddress"
        android:padding="16dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_dim" />

</LinearLayout>