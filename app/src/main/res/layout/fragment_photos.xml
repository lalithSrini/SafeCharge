<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/photos_archive_title"
                style="@style/TextAppearance.SafeCharge.TitleLarge" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/photos_archive_subtitle"
                style="@style/TextAppearance.SafeCharge.BodySmall"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnDeleteAll"
            android:layout_alignBottom="@id/layoutHeader"
            android:layout_marginEnd="8dp"
            android:text="SELECT ALL"
            style="@style/Widget.SafeCharge.Button.Ghost"
            android:textColor="@color/neon_cyan"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/layoutHeader"
            android:text="DELETE ALL"
            style="@style/Widget.SafeCharge.Button.Ghost"
            android:textColor="@color/neon_red"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:minHeight="32dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:rippleColor="#33FF0000" />
    </RelativeLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Photo grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPhotos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp" />

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="60dp"
            android:text="@string/no_photos"
            style="@style/TextAppearance.SafeCharge.BodyMedium"
            android:visibility="gone" />
    </FrameLayout>

</LinearLayout>