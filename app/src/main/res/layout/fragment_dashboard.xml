<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_title"
                style="@style/TextAppearance.SafeCharge.TitleLarge"
                android:textSize="22sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_subtitle"
                style="@style/TextAppearance.SafeCharge.BodySmall"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Status Badge -->
        <LinearLayout
            android:id="@+id/layoutStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/panel_bg"
            android:backgroundTint="@color/neon_green_dim"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="6dp"
            android:paddingEnd="12dp"
            android:paddingBottom="6dp">

            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ic_dashboard"
                android:backgroundTint="@color/neon_green" />

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/status_secure"
                style="@style/TextAppearance.SafeCharge.Mono"
                android:textColor="@color/neon_green" />
        </LinearLayout>

        <!-- Main ARMED Switch -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="32dp">

            <View
                android:id="@+id/viewArmedGlow"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_centerInParent="true"
                android:background="@drawable/armed_button_bg"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="false">

                <ImageView
                    android:id="@+id/iconArmed"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_dashboard"
                    app:tint="@color/neon_cyan" />

                <TextView
                    android:id="@+id/tvArmedStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/status_armed"
                    style="@style/TextAppearance.SafeCharge.Mono"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDisarmHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:text="@string/status_disarm_hint"
                style="@style/TextAppearance.SafeCharge.BodySmall"
                android:textColor="@color/text_dim" />
        </RelativeLayout>

        <!-- Quick Controls Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/log_title"
            style="@style/TextAppearance.SafeCharge.TitleMedium" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <!-- Control: Motion -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/panel_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_dashboard"
                        app:tint="@color/neon_cyan" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchMotion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/control_motion"
                    style="@style/TextAppearance.SafeCharge.TitleMedium"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/control_motion_desc"
                    style="@style/TextAppearance.SafeCharge.BodySmall" />
            </LinearLayout>

            <!-- Control: Camera -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/panel_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_photos"
                        app:tint="@color/neon_cyan" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchCamera"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/control_camera"
                    style="@style/TextAppearance.SafeCharge.TitleMedium"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/control_camera_desc"
                    style="@style/TextAppearance.SafeCharge.BodySmall" />
            </LinearLayout>

            <!-- Control: Email -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/panel_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_alerts"
                        app:tint="@color/neon_cyan" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/control_email"
                    style="@style/TextAppearance.SafeCharge.TitleMedium"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/control_email_desc"
                    style="@style/TextAppearance.SafeCharge.BodySmall" />
            </LinearLayout>

            <!-- Control: Siren -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:background="@drawable/panel_bg"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_alerts"
                        app:tint="@color/neon_red" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchSiren"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/control_siren"
                    style="@style/TextAppearance.SafeCharge.TitleMedium"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/control_siren_desc"
                    style="@style/TextAppearance.SafeCharge.BodySmall" />
            </LinearLayout>
        </GridLayout>

        <!-- Activity Log -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/log_title"
                style="@style/TextAppearance.SafeCharge.TitleMedium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="@string/log_live"
                style="@style/TextAppearance.SafeCharge.Mono"
                android:textColor="@color/neon_red" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/layoutActivityLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvLogEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="System initialised. No logs yet."
                style="@style/TextAppearance.SafeCharge.Mono"
                android:textColor="@color/text_dim" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>