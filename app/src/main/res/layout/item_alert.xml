<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/bg_surface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1AFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/iconAlert"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alerts"
            app:tint="@color/neon_red" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Charger Disconnected"
                style="@style/TextAppearance.SafeCharge.TitleMedium"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="10:25 PM - Today"
                style="@style/TextAppearance.SafeCharge.BodySmall" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteAlert"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconSize="18dp"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/neon_red"
            style="@style/Widget.Material3.Button.IconButton" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="CRITICAL"
            style="@style/TextAppearance.SafeCharge.Mono"
            android:textColor="@color/neon_red"
            android:textSize="10sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>