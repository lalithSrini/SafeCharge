<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/neon_cyan_dim" />
            <size android:width="240dp" android:height="240dp" />
        </shape>
    </item>
    <!-- Border Glow -->
    <item android:top="20dp" android:bottom="20dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <stroke android:width="4dp" android:color="@color/neon_cyan_glow" />
        </shape>
    </item>
    <!-- Main Ring -->
    <item android:top="40dp" android:bottom="40dp" android:left="40dp" android:right="40dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="@color/neon_cyan" />
        </shape>
    </item>
    <!-- Inner Circle -->
    <item android:top="60dp" android:bottom="60dp" android:left="60dp" android:right="60dp">
        <shape android:shape="oval">
            <solid android:color="@color/bg_surface" />
            <stroke android:width="1dp" android:color="@color/neon_cyan_glow" />
        </shape>
    </item>
</layer-list>